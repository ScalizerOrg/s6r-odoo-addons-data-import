#. module: s6r_sale_invoiced_forced_qty
#: model:ir.model.fields,help:s6r_sale_invoiced_forced_qty.field_sale_order_line__untaxed_amount_invoiced_forced
msgid ""
"Amount already invoiced but not related to existing invoices in Odoo (for "
"history data import purposes).        If this field is left blank, the pre-"
"existing amount will not be taken in consideration when calculating the"
"         total invoiced amount for the sale order. Therefore, reports "
"relating to this sale order will be false."
msgstr ""

